# Nano Harness - Environment Variables Example
# Copy this file to .env and fill in your values

# LLM Configuration (OpenAI-compatible endpoint)
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=nemotron-3-nano-30b-a3b

# Optional: Model for subagents (can be same or different)
# SUBAGENT_MODEL=nemotron-3-nano-30b-a3b

# Sandbox (for code execution)
# SANDBOX_TYPE=local  # local, docker, or none
# WORKDIR=/tmp/nano-harness